          "API data collection"
        ]
      },
      {
        "id": "etl-pipelines",
        "description": "Data transformation pipelines",
        "responsibilities": [
          "Data cleaning",
          "Data validation",
          "Data enrichment",
          "Schema evolution"
        ]
      },
      {
        "id": "data-warehouse",
        "description": "Centralized data warehouse",
        "responsibilities": [
          "Data storage",
          "Query optimization",
          "Data modeling",
          "Access control"
        ]
      },
      {
        "id": "feature-store",
        "description": "ML feature store",
        "responsibilities": [
